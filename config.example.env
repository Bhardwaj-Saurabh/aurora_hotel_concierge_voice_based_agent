# Copy to .env and fill in. Never commit real keys.

# Which backend to use: groq (free tier, fast), openai (your key), or
# mock (fully offline  -  no network/key/SDK; scripted responses for testing).
# Groq and OpenAI share the same API dialect, so switching between them is just
# this one line; model names default sensibly per provider (see providers.py).
PROVIDER=groq

# --- Keys (only the selected PROVIDER's key is required) ---
# Get a free Groq key at https://console.groq.com, or use an OpenAI key.
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Optional model overrides (leave blank to use the provider's defaults) ---
# groq defaults:  llama-3.3-70b-versatile / whisper-large-v3-turbo / playai-tts
# openai defaults: gpt-4o-mini / whisper-1 / tts-1
# Example Groq override: llama-3.1-8b-instant for lower latency and weaker tools.
LLM_MODEL=
STT_MODEL=
# Optional multilingual hotel vocabulary supplied to STT as transcription context.
STT_PROMPT=
TTS_MODEL=
TTS_VOICE=
TTS_INSTRUCTIONS=

# Provider resilience: request timeout (seconds) and transport-level retries.
# Failures that survive these produce a spoken fallback, then a transfer.
PROVIDER_TIMEOUT_S=30
PROVIDER_MAX_RETRIES=1

# TTS backend: "provider" (cloud TTS) or "system" (local voice command).
# Groq TTS is in preview and needs terms accepted in the console; if it errors,
# set TTS_BACKEND=system to keep the demo moving at zero cost.
TTS_BACKEND=provider
SYSTEM_TTS_CMD=say
AUDIO_PLAYER_CMD=afplay

# --- Loop tuning (safe defaults) ---
VAD_AGGRESSIVENESS=2     # 0-3, higher = more aggressive silence detection
ENDPOINT_SILENCE_MS=600  # pause length that ends the caller's turn
SAMPLE_RATE=16000
LATENCY_FILLER_MS=1200   # say "One moment." if the turn thinks longer; 0 disables

# Optional JSONL trace destination. Leave blank to keep telemetry in memory.
TELEMETRY_JSONL=../logs/voice-events.jsonl
TELEMETRY_INCLUDE_CONTENT=false
# Optional OpenTelemetry collector (OTLP/HTTP), e.g. http://localhost:4318/v1/traces
# Requires: pip install opentelemetry-exporter-otlp-proto-http
# Generic on purpose (goal.md ADR-009/ADR-019) — this module doesn't know
# about any specific vendor. Example for Opik Cloud (verified live — a bare
# .../otel with no /v1/traces suffix 404s; Comet-Workspace must be your real
# workspace slug, "default" silently 500s):
#   TELEMETRY_OTLP_ENDPOINT=https://www.comet.com/opik/api/v1/private/otel/v1/traces
#   TELEMETRY_OTLP_HEADERS=Authorization=<OPIK_API_KEY>,projectName=<project>,Comet-Workspace=<your-real-workspace-slug>
TELEMETRY_OTLP_ENDPOINT=
TELEMETRY_OTLP_HEADERS=

# Knowledge snapshot pin. Blank = newest knowledge/YYYY-MM-DD/ snapshot.
# Set a snapshot name (e.g. 2026-07-19) to roll back a bad policy edit.
KNOWLEDGE_SNAPSHOT=

# --- Optional local LiveKit room/session demo ---
# Defaults match `scripts/start_local_livekit.sh`.
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM=aurora-demo-room
# How long a minted room token stays valid (goal.md ADR-015). A single call
# session doesn't need the SDK's implicit 6-hour default.
LIVEKIT_TOKEN_TTL_MINUTES=60


# Postgres (goal.md ADR-013/020) — required. Bookings and user-auth both
# hard-require this; there is no local database fallback. Hosted free-tier
# providers (e.g. filess.io) commonly need sslmode=prefer, not require --
# check what your instance actually supports.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=
POSTGRES_DB=your_db_name
POSTGRES_SSLMODE=prefer

# User auth for talk-server's /token, /agent, /voice-agent, /greeting, /reset
# (goal.md ADR-018 — closes ADR-015's documented gap). Requires POSTGRES_HOST
# above; the talk server (aurora.server) refuses to start without it.
AUTH_SESSION_TTL_HOURS=24
# Post-auth cost limiter, keyed by user_id (guards the cost-incurring routes).
AUTH_RATE_LIMIT_PER_HOUR=20
# Pre-auth brute-force limiter on /auth/login and /auth/register, keyed by
# (client IP, email) — the limiter above gives no protection before login.
AUTH_LOGIN_RATE_LIMIT=5
# false only for local http://localhost dev; Fly always serves https.
AUTH_COOKIE_SECURE=true

# Prompt registry — Opik Cloud (goal.md Phase 4.5, ADR-011/019). Blank
# OPIK_API_KEY = SYSTEM_PROMPT (aurora/core/prompts.py) is used as-is, unchanged
# from today's behavior. Any registry hiccup (auth, network, missing prompt)
# falls back to that same local constant — this never dead-ends a call.
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=aurora-hotel
# Name of the prompt in Opik's Prompt Library that holds Aurora's system prompt.
OPIK_PROMPT_NAME=aurora-system-prompt
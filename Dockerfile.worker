# Aurora room-native agent worker (goal.md 3.1/4.1, ADR-008, ADR-012).
#
# Joins the LiveKit room as a participant: subscribes to caller audio, runs
# Silero VAD/turn detection, streams STT/LLM/TTS, publishes replies as a TTS
# track. This is a job worker, not a web service — it registers with the
# LiveKit server/cloud and receives room dispatches; run a POOL of these and
# scale by concurrent call volume, not HTTP traffic. That's why it is a
# separate image from Dockerfile.talk-server: different runtime shape,
# different scaling dimension, and real dependency weight
# (livekit-agents[openai,silero] pulls in ~70MB of onnxruntime) that the
# talk-server image has no reason to carry.
#
# The worker's `start` mode runs a small internal HTTP server (default
# port 8081) for orchestrator health/liveness checks — not a caller-facing
# API. See livekit.agents.WorkerOptions.port.
#
#   docker build -f Dockerfile.worker -t aurora-agent-worker .
#   docker run --rm -p 8081:8081 \
#     -e PROVIDER=openai -e OPENAI_API_KEY=... \    # mock cannot hear/speak
#     -e LIVEKIT_URL=wss://your-project.livekit.cloud \
#     -e LIVEKIT_API_KEY=... -e LIVEKIT_API_SECRET=... \
#     aurora-agent-worker

FROM python:3.12-slim

WORKDIR /app

COPY livekit/requirements.txt livekit/requirements.txt
RUN pip install --no-cache-dir -r livekit/requirements.txt

COPY pipeline/ pipeline/
COPY knowledge/ knowledge/
COPY livekit/ livekit/

ENV TELEMETRY_JSONL=/app/logs/voice-events.jsonl \
    BOOKINGS_DB=/app/logs/bookings.db

EXPOSE 8081

# Never run as root; logs dir is the only writable path the app needs.
RUN mkdir -p /app/logs && useradd --create-home aurora && chown -R aurora /app/logs
USER aurora

CMD ["python", "livekit/agent_worker.py", "start"]
